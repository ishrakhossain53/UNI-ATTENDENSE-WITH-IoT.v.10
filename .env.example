# ============================================================================
# UNIVERSITY ATTENDANCE TRACKING SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update the values for your environment
# DO NOT commit .env to version control - it contains sensitive credentials

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database settings
POSTGRES_DB=attendance_db
POSTGRES_USER=attendance_user
POSTGRES_PASSWORD=SecurePass123!          # CHANGE IN PRODUCTION
POSTGRES_HOST=postgres                     # Docker service name
POSTGRES_PORT=5432

# ============================================================================
# REDIS CONFIGURATION (Session & Cache)
# ============================================================================
# Redis for JWT blacklist, session management, and caching
REDIS_HOST=redis                           # Docker service name
REDIS_PORT=6379

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# JWT Configuration
# Generate secure secret: openssl rand -hex 32
JWT_SECRET=supersecretjwtkey_change_in_production    # CHANGE IN PRODUCTION
JWT_EXPIRY_HOURS=1                         # Token expiration time

# AES Encryption Key (32 characters for AES-256-GCM)
# Generate secure key: openssl rand -hex 16
AES_KEY=0123456789abcdef0123456789abcdef  # CHANGE IN PRODUCTION

# Device Service Authentication Token
# Used by ESP32 devices and gateway to authenticate with backend
# Generate secure token: openssl rand -hex 32
DEVICE_SERVICE_TOKEN=device_service_token_secret_key  # CHANGE IN PRODUCTION

# ============================================================================
# MQTT BROKER CONFIGURATION
# ============================================================================
# Eclipse Mosquitto MQTT broker for device communication
MQTT_BROKER=mosquitto                      # Docker service name
MQTT_PORT=1883                             # Default MQTT port (non-SSL)
# For production, use port 8883 with SSL/TLS enabled

# ============================================================================
# APPLICATION SERVICES
# ============================================================================
# Backend API (FastAPI)
BACKEND_URL=http://backend:8000            # Internal Docker network URL
BACKEND_PORT=8000                          # External port mapping

# Frontend Web Application (React + Nginx)
FRONTEND_PORT=3000                         # External port mapping

# ============================================================================
# BUSINESS LOGIC CONFIGURATION
# ============================================================================
# Attendance threshold percentage for at-risk student alerts
# Students below this percentage will be flagged
ATTENDANCE_THRESHOLD=75

# Gateway sync polling interval (seconds)
# How often gateway checks for pending fingerprint template syncs
SYNC_POLL_INTERVAL=30

# ESP32 Device Configuration
# Scan interval range (seconds) - random interval between min and max
# Simulates realistic fingerprint scanning behavior
ESP32_SCAN_INTERVAL_MIN=10
ESP32_SCAN_INTERVAL_MAX=20

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure you:
# 
# 1. SECURITY:
#    - Change JWT_SECRET to a strong random string (min 32 characters)
#    - Generate a secure 32-character AES_KEY
#    - Use a strong POSTGRES_PASSWORD
#    - Generate a secure DEVICE_SERVICE_TOKEN
#    - Enable MQTT authentication in mosquitto/config/mosquitto.conf
#    - Set up SSL/TLS certificates for HTTPS
#    - Configure proper firewall rules
#
# 2. PERFORMANCE:
#    - Increase JWT_EXPIRY_HOURS for production (e.g., 8-24 hours)
#    - Adjust SYNC_POLL_INTERVAL based on device count
#    - Configure database connection pooling
#    - Enable Redis persistence
#
# 3. MONITORING:
#    - Set up logging aggregation (ELK stack, CloudWatch, etc.)
#    - Configure health check endpoints
#    - Set up alerting for critical errors
#    - Monitor database and Redis performance
#
# 4. BACKUP:
#    - Configure automated PostgreSQL backups
#    - Set up Redis persistence (RDB/AOF)
#    - Document disaster recovery procedures
#
# 5. NETWORKING:
#    - Use reverse proxy (Nginx/Traefik) with SSL termination
#    - Configure CORS properly for production domain
#    - Set up rate limiting beyond default settings
#    - Use environment-specific URLs (not localhost)
#
# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
# - Default credentials are in database/init.sql
# - Admin: admin / admin123
# - Faculty: faculty1, faculty2 / pass123
# - Students: student01-student10 / pass123
# - All passwords are bcrypt-hashed in the database
# - WebSocket endpoint: ws://localhost:3000/ws/attendance?token={jwt}
# - API documentation: http://localhost:8000/docs
